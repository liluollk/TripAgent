server:
  port: 8081

spring:
  application:
    name: trip-tools-server
  ai:
    mcp:
      server:
        enabled: true
        name: trip-tools
        version: 1.0.0
        type: SYNC
        protocol: STREAMABLE
        request-timeout: 120s

logging:
  level:
    org.springframework.ai.mcp: DEBUG
    io.modelcontextprotocol: DEBUG

trip:
  weather:
    api-key: ${QWEATHER_API_KEY:your-qweather-api-key-here}
    host: ${QWEATHER_HOST:your-qweather-host-here}
    geo-host: ${QWEATHER_GEO_HOST:your-qweather-geo-host-here}
  amap:
    api-key: ${AMAP_API_KEY:your-amap-api-key-here}
